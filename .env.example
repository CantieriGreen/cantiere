# ============================================================
# EdilControl - environment variables
# Copia questo file in .env.local e compila i valori reali.
# .env.local è in .gitignore e non viene committato.
# ============================================================

# --- Supabase (frontend) ---
# https://app.supabase.com/project/<id>/settings/api
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# --- Resend (verrà usato dal giorno 9-10 per email) ---
# https://resend.com/api-keys
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=noreply@dominio.it

# --- Solo per script di migration locali (NON usare in frontend) ---
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
